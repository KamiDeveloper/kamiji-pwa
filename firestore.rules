rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validEncryptedKey(bundle) {
      return bundle is map
        && bundle.keys().hasOnly(['encrypted', 'salt', 'iv'])
        && bundle.encrypted is string
        && bundle.salt is string
        && bundle.iv is string;
    }

    function validUserDocument(data) {
      return data.keys().hasOnly([
        'level',
        'totalLearned',
        'streak',
        'lastStudiedAt',
        'updatedAt',
        'geminiKey'
      ]) && (
        !('geminiKey' in data) || validEncryptedKey(data.geminiKey)
      );
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && validUserDocument(request.resource.data);
      allow delete: if false;

      match /kanji/{kanjiId} {
        allow read, write: if isOwner(userId);
      }

      match /progress/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
